    "isomorphic-dompurify": "^3.17.0",
    "lucide-react": "^1.18.0",
    "next": "^15.2.3",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
